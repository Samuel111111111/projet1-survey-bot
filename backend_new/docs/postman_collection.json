{
  "info": {
    "name": "Survey Bot API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for the Survey Bot backend. Configure the `base_url` and `access_token` variables in your Postman environment before sending requests."
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "campaign_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"admin\",\n  \"password\": \"admin123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Campaigns",
      "item": [
        {
          "name": "List Campaigns",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/campaigns/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "campaigns",
                ""
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Campaign",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/campaigns/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "campaigns",
                ""
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Campaign\",\n  \"description\": \"Example\",\n  \"status\": \"Draft\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Sessions",
      "item": [
        {
          "name": "Generate Sessions",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/campaigns/{{campaign_id}}/sessions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "campaigns",
                "{{campaign_id}}",
                "sessions"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"count\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Statistics",
      "item": [
        {
          "name": "Campaign Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/campaigns/{{campaign_id}}/stats",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "campaigns",
                "{{campaign_id}}",
                "stats"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Stats Overview",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/stats/overview",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "stats",
                "overview"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Export",
      "item": [
        {
          "name": "Export Responses CSV",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/campaigns/{{campaign_id}}/export?format=csv",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "campaigns",
                "{{campaign_id}}",
                "export"
              ],
              "query": [
                {
                  "key": "format",
                  "value": "csv"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Export Responses Excel",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/campaigns/{{campaign_id}}/export?format=xlsx",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "campaigns",
                "{{campaign_id}}",
                "export"
              ],
              "query": [
                {
                  "key": "format",
                  "value": "xlsx"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Export Power BI",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/campaigns/{{campaign_id}}/export?format=powerbi",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "campaigns",
                "{{campaign_id}}",
                "export"
              ],
              "query": [
                {
                  "key": "format",
                  "value": "powerbi"
                }
              ]
            }
          },
          "response": []
        }
      ]
    }
  ]
}